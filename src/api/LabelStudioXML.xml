<View>
  <View style="display:flex; gap:24px;">
    <View style="width:70%;">
      <Labels name="label" toName="audio">
        <Label value="Frog Call" />
        <Label value="Noise" />
      </Labels>
      <Audio name="audio" value="$audio" spectrogram="true" />
    </View>

    <View style="width:30%;">
      <Header value="File Details" />
      <Text name="file1" value="Filename: $filename" />
      <Text name="file2" value="Sample Rate: $sampleRate Hz" />
      <Text name="file3" value="Channels: $channels" />
      <Text name="file4" value="Bitrate: $bitrate kbps" />
      <Text name="file5" value="Version: $version" />
      <Text name="file6" value="Max Frequency: $maxFrequency Hz" />
    </View>
  </View>
</View>